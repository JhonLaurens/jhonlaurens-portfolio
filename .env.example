# Application Settings
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=jhonlaurens-portfolio
NEXT_PUBLIC_APP_VERSION=1.0.1

# API Configuration
API_BASE_URL=https://jhonlaurens.vercel.app/api
API_TIMEOUT=30000

# Supabase/Postgres server-side connection
# Use either DATABASE_URL or the separated values below.
# Keep real values in .env or Vercel environment variables, never in public JS.
DATABASE_URL=postgresql://postgres.project-ref:password@aws-region.pooler.supabase.com:6543/postgres
HOST_NAME=aws-region.pooler.supabase.com
DATABASE_NAME=postgres
PORT=6543
USUARIO_NAME=postgres.project-ref
PASS_DB=your-database-password

# Supabase public values, only needed if using direct browser Supabase calls.
PROJECT_ID=your-project-ref
URL_SUPABASE=https://your-project-ref.supabase.co
PUBLISHABLE_KEY=your-supabase-publishable-key

# SEO Settings
NEXT_PUBLIC_SITE_URL=https://jhonlaurens.vercel.app
NEXT_PUBLIC_SITE_NAME=Jhon Laurens Portfolio
NEXT_PUBLIC_SITE_DESCRIPTION=Portfolio profesional de Jhon Laurens - Data Engineer & AI Specialist

# Social Media
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/jhonlaurens
NEXT_PUBLIC_GITHUB_URL=https://github.com/jhonlaurens
NEXT_PUBLIC_EMAIL=jhonlaurens@gmail.com

# Performance Settings
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=true
NEXT_PUBLIC_CACHE_DURATION=3600

# Security Settings
NEXT_PUBLIC_CSP_REPORT_URI=
NEXT_PUBLIC_ALLOWED_ORIGINS=https://jhonlaurens.vercel.app,https://jhonlaurens.dev
