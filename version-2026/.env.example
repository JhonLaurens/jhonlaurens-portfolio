# Copia este archivo como .env.local para desarrollo local.
# En Vercel configura estas variables en Project Settings > Environment Variables.

# Recomendado
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Alternativa compatible con el proyecto actual
HOST_NAME=db.example.supabase.co
PORT=5432
DATABASE_NAME=postgres
USUARIO_NAME=postgres
PASS_DB=change-me

# Public site metadata
SITE_URL=https://jhonlaurens-portfolio.vercel.app
